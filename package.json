{
  "name": "lingolion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "LingoLion - AI-powered language learning platform by Royal KrAss Group",
  "author": "KinGKrAss",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite --port=3000 --host=0.0.0.0",
    "server:dev": "tsx watch server.ts",
    "build": "vite build",
    "build:full": "npm run build && npm run server:build",
    "server:build": "tsc server.ts --outDir dist --module esnext --target es2020 --moduleResolution node --esModuleInterop",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "start:dev": "tsx server.ts",
    "clean": "rm -rf dist node_modules",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "nodemailer": "^6.9.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}